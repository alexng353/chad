{
	"name": "chad",
	"version": "0.6.0",
	"type": "module",
	"bin": {
		"chad": "./src/index.ts"
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bun build --compile --define \"__CHAD_VERSION__=\\\"$(jq -r .version package.json)\\\"\" --minify src/index.ts --outfile chad",
		"release": "bun run scripts/release.ts",
		"lint": "bunx biome check --fix --unsafe",
		"format": "bunx biome format --write"
	},
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/bun": "latest"
	}
}
